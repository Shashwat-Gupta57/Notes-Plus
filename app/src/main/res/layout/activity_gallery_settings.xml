<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarSettings"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Settings"
            app:titleTextColor="#000000"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="VAULT MANAGEMENT"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewVaults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <Button
                android:id="@+id/btnAddVault"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="+ Create New Vault"
                android:textColor="#FFCC00" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="VAULT INTERIOR BACKGROUND (CURRENT)"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                app:singleLine="false">
                <Button android:id="@+id/btnVaultBgDefault" android:text="Default" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnVaultBgColor" android:text="Color" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnVaultBgImage" android:text="Image" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnVaultBgVideo" android:text="Video" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnVaultBgUrl" android:text="URL" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </com.google.android.material.chip.ChipGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="LOCK SCREEN BACKGROUND (GLOBAL)"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                app:singleLine="false">
                <Button android:id="@+id/btnLockBgDefault" android:text="Default" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnLockBgColor" android:text="Color" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnLockBgImage" android:text="Image" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnLockBgVideo" android:text="Video" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <Button android:id="@+id/btnLockBgUrl" android:text="URL" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </com.google.android.material.chip.ChipGroup>

            <LinearLayout
                android:id="@+id/layoutLockBgOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:visibility="gone">
                <CheckBox
                    android:id="@+id/checkLockBgBlur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Blur (Images only)"/>
                <CheckBox
                    android:id="@+id/checkLockBgDim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dim Overlay"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="BACKUP"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/optionCreateBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="16dp"
                android:text="Create Local Backup"
                android:textColor="#000000"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="CLOUD BACKUP"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/layoutGoogleDrive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textDriveAccount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not connected to Google Drive"
                            android:textColor="#000000"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/textDriveLastSync"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Last sync: Never"
                            android:textColor="#8E8E93"
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/syncIconContainer"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:visibility="gone">

                        <ProgressBar
                            android:id="@+id/syncProgressBar"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="true"
                            android:indeterminateTint="#FFCC00"
                            android:visibility="invisible" />

                        <ImageView
                            android:id="@+id/syncStatusIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_sync"
                            android:contentDescription="Sync Status" />
                    </FrameLayout>
                </RelativeLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchAutoSync"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Automatic Sync"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnDriveAction"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Connect Google Drive" />

                    <Button
                        android:id="@+id/btnDriveSyncNow"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="12dp"
                        android:text="Sync Now"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="DATA RECOVERY"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/optionRestoreData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="16dp"
                android:text="Restore / Retrieve Data"
                android:textColor="#000000"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="SECURITY"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/optionChangeLock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="16dp"
                android:text="Change Main Vault Lock"
                android:textColor="#000000"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="AUTO-LOCK"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <RadioGroup
                android:id="@+id/radioGroupAutoLock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <RadioButton
                    android:id="@+id/radioImmediately"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Immediately"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/radio30s"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="After 30 seconds"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/radio1m"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="After 1 minute"
                    android:textSize="16sp" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="UPDATES"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textUpdateStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="App is up to date"
                android:textColor="#8E8E93"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnCheckUpdates"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Check for Updates"
                android:textColor="#FFCC00" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>