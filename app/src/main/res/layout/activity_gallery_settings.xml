<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarSettings"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Settings"
            app:titleTextColor="#000000"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="VAULT MANAGEMENT"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewVaults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <Button
                android:id="@+id/btnAddVault"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="+ Create New Vault"
                android:textColor="#FFCC00" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="VAULT INTERIOR BACKGROUND (CURRENT)"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">
                <Button
                    android:id="@+id/btnVaultBgDefault"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Default"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
                <Button
                    android:id="@+id/btnVaultBgColor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Color"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
                <Button
                    android:id="@+id/btnVaultBgImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Image"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="LOCK SCREEN BACKGROUND (GLOBAL)"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp">
                <Button
                    android:id="@+id/btnLockBgDefault"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Default"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
                <Button
                    android:id="@+id/btnLockBgColor"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Color"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
                <Button
                    android:id="@+id/btnLockBgImage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Image"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutLockBgOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:visibility="gone">
                <CheckBox
                    android:id="@+id/checkLockBgBlur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Blur Background Image"/>
                <CheckBox
                    android:id="@+id/checkLockBgDim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dim Background Image"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="SECURITY"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/optionChangeLock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="16dp"
                android:text="Change Main Vault Lock"
                android:textColor="#000000"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginStart="16dp"
                android:background="#E5E5EA" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="AUTO-LOCK"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <RadioGroup
                android:id="@+id/radioGroupAutoLock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <RadioButton
                    android:id="@+id/radioImmediately"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Immediately"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/radio30s"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="After 30 seconds"
                    android:textSize="16sp" />

                <RadioButton
                    android:id="@+id/radio1m"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="After 1 minute"
                    android:textSize="16sp" />
            </RadioGroup>
        </LinearLayout>
    </ScrollView>
</LinearLayout>