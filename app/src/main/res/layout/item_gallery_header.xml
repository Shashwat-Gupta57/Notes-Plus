<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    android:background="#F2F2F7">

    <TextView
        android:id="@+id/dateHeaderText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:padding="8dp"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#8E8E93" />

    <FrameLayout
        android:id="@+id/headerSelectionContainer"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/headerCheckCircleBase"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check_circle_empty"
            android:alpha="0.5" />

        <ImageView
            android:id="@+id/headerCheckCircleFilled"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check_circle_filled"
            android:visibility="gone" />
    </FrameLayout>
</RelativeLayout>